# Mohe Platform Environment Configuration
# Copy this file to .env and fill in your actual values

# Database Configuration
POSTGRES_DB=mohe_db
POSTGRES_USER=mohe_user
POSTGRES_PASSWORD=mohe_password
POSTGRES_PORT=5432

# Spring Application Database Config (maps to application.yml)
DB_USERNAME=mohe_user
DB_PASSWORD=mohe_password

# API Keys (REQUIRED - Get from respective platforms)
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
GOOGLE_CUSTOM_SEARCH_API_KEY=your_google_custom_search_api_key_here
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=your_google_custom_search_engine_id_here
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# LLM Configuration - Choose AI provider
IS_OPENAI_ACTIVE=true  # true = use OpenAI, false = use Ollama

# OpenAI Configuration (if IS_OPENAI_ACTIVE=true)
OPENAI_MODEL=gpt-3.5-turbo

# Ollama Configuration (if IS_OPENAI_ACTIVE=false)
OLLAMA_HOST=http://your_ollama_server_ip:11434
OLLAMA_MODEL=your_model_name
OLLAMA_TIMEOUT=120

# Service Ports
BACKEND_PORT=8080
BATCH_WEB_PORT=8082
BATCH_PROCESSOR_PORT=8084
FRONTEND_PORT=3000
MOCK_API_PORT=3001

# Management Ports
BATCH_WEB_MANAGEMENT_PORT=8083
BATCH_PROCESSOR_MANAGEMENT_PORT=8085

# Batch Configuration
BATCH_CHUNK_SIZE=500
BATCH_SKIP_LIMIT=100
BATCH_AUTO_START=false
BATCH_SCHEDULING_ENABLED=true
BATCH_CRON=0 */60 * * * ?  # Every hour

# API Configuration
API_PAGE_SIZE=100
API_MAX_PAGES=10
API_TIMEOUT=30

# Security (IMPORTANT: Change for production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Environment
SPRING_PROFILES_ACTIVE=docker
ENVIRONMENT=docker
LOG_LEVEL=INFO

# Optional Monitoring (uncomment to enable)
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3002
# GRAFANA_PASSWORD=admin